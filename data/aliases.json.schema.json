{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unity-asset-skills/aliases.json.schema.json",
  "title": "Aliases Dictionary",
  "description": "data/aliases.yml의 구조 검증 스키마 (CRIT-SCH5). 한↔영 별칭 사전. 한글 token을 영문 alias 배열로 매핑하여 Search 1차 라우팅 prompt에 hint로 첨부된다.",
  "type": "object",
  "required": ["version", "aliases"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "스키마 버전. 현재 1."
    },
    "aliases": {
      "type": "object",
      "description": "한글 키워드를 영문 alias 배열로 매핑. key는 사용자 쿼리에서 발견될 수 있는 한글 token, value는 routing subagent에 전달되는 영문 alias 배열.",
      "minProperties": 1,
      "patternProperties": {
        "^.+$": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9-]*$",
            "description": "영문 alias. 소문자/하이픈 권장 (예: 'top-down', 'scriptable-object')."
          }
        }
      },
      "additionalProperties": false
    }
  }
}
